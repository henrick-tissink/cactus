{
  "name": "cactus",
  "private": true,
  "scripts": {
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.2.10"
  },
  "lint-staged": {
    "src/frontend/src/**/*.{ts,tsx}": [
      "npm exec --prefix src/frontend -- prettier --write",
      "npm exec --prefix src/frontend -- eslint --fix --config src/frontend/eslint.config.js"
    ],
    "src/frontend/src/**/*.{css,json}": [
      "npm exec --prefix src/frontend -- prettier --write"
    ]
  }
}
