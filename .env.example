# Cactus environment variables
# Copy this file to `.env` and adjust values for local dev.
# Required for `docker compose up` and `docker compose -f docker-compose.dev.yml up`.
# Production overrides these on the server (see /opt/cactus/.env on the host).

# Postgres password used by both the postgres container and the API connection string.
# Local dev default below is safe; rotate in prod.
POSTGRES_PASSWORD=cactus_dev

# JWT signing key for the API (must be ≥32 chars).
# Local dev default below is safe; rotate in prod.
JWT_KEY=DevOnlySecretKey_DoNotUseInProduction_AtLeast32Chars!
